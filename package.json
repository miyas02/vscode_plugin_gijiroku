{
  "name": "custom-gijiroku",
  "displayName": "custom_gijiroku",
  "description": "---",
  "version": "0.0.2",
  "publisher": "custom-gijiroku",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "custom_gijiroku",
      "properties": {                                                                                                     
        "custom_gijiroku.enable": {
          "type": "boolean",
          "default": true,
          "description": "機能を有効にする"
        },
        "custom_gijiroku.replacements": {
          "type": "array",
          "default": [{ "targetText": "star", "replaceChar": "★" }],
          "description": "置換ルールの一覧",
          "items": {
            "type": "object",
            "properties": {
              "targetText": {
                "type": "string",
                "description": "置換対象（正規表現）"
              },
              "replaceChar": {
                "type": "string",
                "description": "置換後の文字列"
              }
            }
          }
        }                                                                                                                 
      }                                                                                                                   
    },
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./main.js"
    ],
    "commands": [
      {
        "command": "plugin-2.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/highlight.js": "^9.12.4",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-emoji": "^3.0.0"
  }
}
